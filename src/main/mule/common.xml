<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:http="http://www.mulesoft.org/schema/mule/http"
	xmlns="http://www.mulesoft.org/schema/mule/core" xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd">
	
	<sub-flow name="common-http-request-flow" doc:id="7449ba2c-da37-4435-8944-6859f209de2a" >
		<logger level="INFO" doc:name="Before HTTP Request Log" doc:id="8b7ace34-9728-4c37-a3f2-2c2c54966b04" message='#[output application/json&#10;---&#10;{&#10;	"flowName": "scheduler-scdp-orchestration-main-flow",&#10;	"tracePoint": "BEFORE REQUEST",&#10;	"contentSize": sizeOf(payload) default 0&#10;}]'/>
		<http:request method="#[vars.httpDetails.method]" doc:name="HTTP Request to External System" doc:id="0108e1ca-8a6c-4dea-80e4-d721d8982b26" responseTimeout="${http.timeout}" config-ref="HTTP_Request_configuration" path="#[vars.httpDetails.path]">
			<http:headers ><![CDATA[#[{
	"client_id": vars.httpDetails.clientId,
	"client_secret": vars.httpDetails.clientSecret,
	"Content-Type": "application/json"
}]]]></http:headers>
			<http:query-params ><![CDATA[#[%dw 2.0
output application/json
---
{
    //"query"      : vars.query default "",
    "reportName" : vars.reportName default ""
}]]]></http:query-params>
		</http:request>
		<logger level="INFO" doc:name="After HTTP Request Log" doc:id="8e3c6c00-6e5f-4807-9e3b-9e418310c948" message='#[output application/json&#10;---&#10;{&#10;	"flowName": "scheduler-scdp-orchestration-main-flow",&#10;	"tracePoint": "AFTER REQUEST",&#10;	"statusCode": attributes.statusCode default "",&#10;	"contentSize": sizeOf(payload) default 0&#10;}]'/>
	</sub-flow>
	
</mule>
